root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.py]
indent_size = 4

[*.{md,markdown}]
indent_size = 2
trim_trailing_whitespace = false  # markdown uses trailing spaces for line breaks

[*.{yml,yaml,json}]
indent_size = 2

[*.csv]
trim_trailing_whitespace = false  # cells may legitimately end in spaces

[Makefile]
indent_style = tab
